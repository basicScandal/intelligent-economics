---
/* Zone Zero Simulator — full markup extracted from monolith HTML.
   All IDs, classes, and attributes preserved for script attachment in Plan 03. */
---

<section class="zone-zero section" id="zone-zero" aria-label="Zone Zero Simulator">
  <div class="container">

    <div class="zone-zero__header reveal">
      <div class="section-label">Interactive Simulation</div>
      <h2 class="section-title">Zone Zero</h2>
      <p class="section-body">
        Configure your pilot city's four capitals. Watch the ecosystem bloom when all four are strong — and collapse toward zero the moment any single dimension hits the floor. This is the multiplicative trap GDP ignores.
      </p>
    </div>

    <div class="zone-zero__inner">

      <!-- LEFT: Sliders -->
      <div class="zone-zero__sliders" aria-label="MIND dimension sliders">
        <div class="zone-zero__sliders-title">Configure Pilot City</div>

        <!-- M -->
        <div class="zz-slider-row">
          <div class="zz-slider-header">
            <label class="zz-slider-label" for="zz-m">
              <span class="zz-slider-dot zz-slider-dot--m"></span>
              Material Capital
            </label>
            <span class="zz-slider-val zz-slider-val--m" id="zz-m-val" aria-live="polite">70</span>
          </div>
          <input class="zz-range zz-range--m" type="range" id="zz-m" min="0" max="100" value="70"
                 aria-label="Material Capital score 0 to 100" style="--pct:70%">
          <span class="zz-slider-desc">Infrastructure, energy, housing, physical commons</span>
          <span class="zz-floor-warning" id="zz-m-warn" aria-live="assertive">&#9888; Floor reached — cascade collapse</span>
        </div>

        <!-- I -->
        <div class="zz-slider-row">
          <div class="zz-slider-header">
            <label class="zz-slider-label" for="zz-i">
              <span class="zz-slider-dot zz-slider-dot--i"></span>
              Intelligence Capital
            </label>
            <span class="zz-slider-val zz-slider-val--i" id="zz-i-val" aria-live="polite">60</span>
          </div>
          <input class="zz-range zz-range--i" type="range" id="zz-i" min="0" max="100" value="60"
                 aria-label="Intelligence Capital score 0 to 100" style="--pct:60%">
          <span class="zz-slider-desc">Education, open knowledge, cognitive infrastructure</span>
          <span class="zz-floor-warning" id="zz-i-warn" aria-live="assertive">&#9888; Floor reached — cascade collapse</span>
        </div>

        <!-- N -->
        <div class="zz-slider-row">
          <div class="zz-slider-header">
            <label class="zz-slider-label" for="zz-n">
              <span class="zz-slider-dot zz-slider-dot--n"></span>
              Network Capital
            </label>
            <span class="zz-slider-val zz-slider-val--n" id="zz-n-val" aria-live="polite">50</span>
          </div>
          <input class="zz-range zz-range--n" type="range" id="zz-n" min="0" max="100" value="50"
                 aria-label="Network Capital score 0 to 100" style="--pct:50%">
          <span class="zz-slider-desc">Cooperative density, trust, inter-node connectivity</span>
          <span class="zz-floor-warning" id="zz-n-warn" aria-live="assertive">&#9888; Floor reached — cascade collapse</span>
        </div>

        <!-- D -->
        <div class="zz-slider-row">
          <div class="zz-slider-header">
            <label class="zz-slider-label" for="zz-d">
              <span class="zz-slider-dot zz-slider-dot--d"></span>
              Diversity Capital
            </label>
            <span class="zz-slider-val zz-slider-val--d" id="zz-d-val" aria-live="polite">40</span>
          </div>
          <input class="zz-range zz-range--d" type="range" id="zz-d" min="0" max="100" value="40"
                 aria-label="Diversity Capital score 0 to 100" style="--pct:40%">
          <span class="zz-slider-desc">Cognitive, cultural, ecological, economic variety</span>
          <span class="zz-floor-warning" id="zz-d-warn" aria-live="assertive">&#9888; Floor reached — cascade collapse</span>
        </div>

      </div><!-- /sliders -->

      <!-- CENTRE: Particle canvas -->
      <div class="zone-zero__canvas-wrap">
        <span class="zz-canvas-label">Pilot City Ecosystem</span>
        <canvas id="zz-canvas"></canvas>
        <!-- Collapse overlay -->
        <div class="zz-collapse-overlay" id="zz-collapse-overlay" aria-live="assertive" aria-atomic="true">
          <div class="zz-collapse-overlay__icon" aria-hidden="true">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
              <circle cx="24" cy="24" r="22" stroke="#ff4455" stroke-width="2" stroke-dasharray="4 4"/>
              <path d="M24 14v12M24 32v2" stroke="#ff4455" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="zz-collapse-overlay__text" id="zz-collapse-dim">Systemic Collapse</div>
          <div class="zz-collapse-overlay__sub" id="zz-collapse-reason">A single dimension at zero pulls the entire system to zero. This is the multiplicative trap.</div>
        </div>
      </div>

      <!-- RIGHT: Score panel -->
      <div class="zone-zero__score">

        <div class="zz-score-block">
          <div class="zz-score-label">MIND Score</div>
          <div class="zz-score-number" id="zz-score-num" aria-live="polite" aria-atomic="true">52</div>
        </div>

        <div class="zz-score-divider"></div>

        <div class="zz-health-state">
          <span class="zz-health-badge thriving" id="zz-health-badge">Thriving</span>
          <div class="zz-health-name" id="zz-health-name">Symbiotic Zone</div>
          <p class="zz-health-insight" id="zz-health-insight">
            All four capitals are mutually reinforcing. The city is a candidate for nucleation — a proof-of-concept others can imitate.
          </p>
        </div>

        <div class="zz-score-divider"></div>

        <div class="zz-constraint" id="zz-constraint-block">
          <strong id="zz-constraint-title">Binding Constraint</strong>
          <span id="zz-constraint-text">Diversity (40) is the binding constraint. Raising it first yields the highest marginal return on total MIND score.</span>
        </div>

        <button class="zz-reset-btn" id="zz-reset" aria-label="Reset all sliders to default values">
          Reset to defaults
        </button>

        <!-- Share panel -->
        <div class="zz-share-panel" id="zz-share-panel">
          <div class="zz-shared-banner" id="zz-shared-banner">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1a7 7 0 1 1 0 14A7 7 0 0 1 8 1Zm0 1.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM8 6a1 1 0 0 1 1 1v3.5a1 1 0 0 1-2 0V7a1 1 0 0 1 1-1Zm0-2.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2Z" fill="currentColor"/></svg>
            Viewing a shared configuration
          </div>
          <div class="zz-share-label">Share this city</div>
          <div class="zz-share-row">
            <button class="zz-share-btn" id="zz-copy-btn" aria-label="Copy shareable link to clipboard">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H6Zm0-1.5h6A2.5 2.5 0 0 1 14.5 4v8a2.5 2.5 0 0 1-2.5 2.5H6A2.5 2.5 0 0 1 3.5 12V4A2.5 2.5 0 0 1 6 1.5ZM3 4.5A1 1 0 0 0 2 5.5v7A2.5 2.5 0 0 0 4.5 15H10a1 1 0 0 0 0-2H4.5A.5.5 0 0 1 4 12.5v-7a1 1 0 0 0-1-1Z" fill="currentColor"/></svg>
              <span id="zz-copy-label">Copy link</span>
            </button>
            <a class="zz-share-btn twitter" id="zz-twitter-btn" href="#" target="_blank" rel="noopener" aria-label="Share on X / Twitter">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M12.6 1h2.4L9.72 7.19 15.6 15h-4.63l-3.81-5.03L2.84 15H.44l5.65-6.56L.4 1h4.75l3.45 4.56L12.6 1Zm-.84 12.6h1.33L4.36 2.37H2.93l8.83 11.23Z" fill="currentColor"/></svg>
              Post
            </a>
            <a class="zz-share-btn linkedin" id="zz-linkedin-btn" href="#" target="_blank" rel="noopener" aria-label="Share on LinkedIn">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M1.5 2.75C1.5 2.06 2.06 1.5 2.75 1.5h10.5c.69 0 1.25.56 1.25 1.25v10.5c0 .69-.56 1.25-1.25 1.25H2.75c-.69 0-1.25-.56-1.25-1.25V2.75ZM5 6.5H3.5v5H5v-5ZM4.25 5.75a.875.875 0 1 0 0-1.75.875.875 0 0 0 0 1.75Zm4.75 5.75V9a.75.75 0 0 1 1.5 0v2.5H12V9c0-1.24-1.01-2.25-2.25-2.25S7.5 7.76 7.5 9v2.5H9Z" fill="currentColor"/></svg>
              Share
            </a>
          </div>
        </div>

      </div><!-- /score -->

    </div><!-- /inner -->
  </div>

  <noscript><p class="zz-noscript">Enable JavaScript to use the interactive Zone Zero simulator.</p></noscript>
</section>

<script>
  import { initZoneZero } from '../scripts/zone-zero';

  const container = document.getElementById('zone-zero');
  if (container) {
    initZoneZero(container);
  }
</script>
