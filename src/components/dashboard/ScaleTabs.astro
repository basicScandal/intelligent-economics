---
// ScaleTabs — Tab navigation for dashboard scale switching.
// Purely presentational; JS in init.ts manages active state.
---

<nav id="scale-tabs" role="tablist" aria-label="Analysis scale" class="flex gap-2 mb-6 bg-surface-2 rounded-full p-1 w-fit mx-auto">
  <button
    role="tab"
    id="tab-country"
    aria-selected="true"
    aria-controls="scale-country"
    data-scale="country"
    tabindex="0"
    class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium bg-white/10 text-white transition-colors"
  >
    Country
  </button>
  <button
    role="tab"
    id="tab-city"
    aria-selected="false"
    aria-controls="scale-city"
    data-scale="city"
    tabindex="-1"
    class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium text-[#8888aa] hover:text-white transition-colors"
  >
    City
  </button>
  <button
    role="tab"
    id="tab-firm"
    aria-selected="false"
    aria-controls="scale-firm"
    data-scale="firm"
    tabindex="-1"
    class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium text-[#8888aa] hover:text-white transition-colors"
  >
    Firm
  </button>
  <button
    role="tab"
    id="tab-map"
    aria-selected="false"
    aria-controls="scale-map"
    data-scale="map"
    tabindex="-1"
    class="inline-flex items-center rounded-full px-4 py-2 text-sm font-medium text-[#8888aa] hover:text-white transition-colors"
  >
    Map
  </button>
</nav>
