  .compare-table th {
    text-align: left;
    padding: 0.75rem;
    border-bottom: 2px solid var(--wp-border);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
