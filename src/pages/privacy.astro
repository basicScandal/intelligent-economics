---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy">
  <main class="min-h-screen py-16 px-4">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-display text-3xl md:text-4xl font-bold text-text mb-8">
        Privacy Policy
      </h1>
      <p class="text-text-muted leading-relaxed">
        Full privacy policy content will be migrated from the existing site in Phase 2.
        Intelligent Economics is committed to protecting your privacy and handling your data
        with transparency.
      </p>
    </div>
  </main>
</BaseLayout>
