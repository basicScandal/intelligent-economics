---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import EmailCapture from '../components/EmailCapture.astro';
import MindDashboard from '../components/MindDashboard.astro';
import ZoneZeroSimulator from '../components/ZoneZeroSimulator.astro';
import Inversion from '../components/Inversion.astro';
import MetabolicRift from '../components/MetabolicRift.astro';
import Pillars from '../components/Pillars.astro';
import Stories from '../components/Stories.astro';
import AfterVolunteer from '../components/AfterVolunteer.astro';
import LocalExperiments from '../components/LocalExperiments.astro';
import VolunteerForm from '../components/VolunteerForm.astro';
import Paths from '../components/Paths.astro';
import Partners from '../components/Partners.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Build the Next World">
  <header role="banner">
    <Nav />
  </header>
  <main id="main-content">
    <Hero />
    <Ticker />
    <EmailCapture />
    <MindDashboard />
    <ZoneZeroSimulator />
    <Inversion />
    <MetabolicRift />
    <Pillars />
    <Stories />
    <AfterVolunteer />
    <LocalExperiments />
    <VolunteerForm />
    <Paths />
    <Partners />
    <FinalCTA />
  </main>
  <Footer />
</BaseLayout>
