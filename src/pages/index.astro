---
import BaseLayout from '../layouts/BaseLayout.astro';
import ZoneZeroSimulator from '../components/ZoneZeroSimulator.astro';
import Stories from '../components/Stories.astro';
import LocalExperiments from '../components/LocalExperiments.astro';
---
<BaseLayout title="Home">
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center space-y-6 px-4">
      <h1 class="font-display text-4xl md:text-6xl font-bold text-primary">
        Intelligent Economics
      </h1>
      <p class="text-text-muted text-lg max-w-2xl mx-auto">
        Material x Intelligence x Network x Diversity = Prosperity
      </p>
      <div class="flex gap-4 justify-center mt-8">
        <span class="inline-block px-4 py-2 rounded-lg bg-surface border border-border text-primary font-medium">
          Primary
        </span>
        <span class="inline-block px-4 py-2 rounded-lg bg-surface border border-border text-secondary font-medium">
          Secondary
        </span>
        <span class="inline-block px-4 py-2 rounded-lg bg-surface border border-border text-tertiary font-medium">
          Tertiary
        </span>
      </div>
    </div>
  </main>

  <ZoneZeroSimulator />
  <Stories />
  <LocalExperiments />
</BaseLayout>
